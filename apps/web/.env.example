# Web client configuration (copy to .env.local for local overrides)

# URL of the authoritative Socket.IO server (the apps/server backend). Must be
# reachable from the browser. This is a NEXT_PUBLIC_* var, so it is baked into
# the static build at BUILD TIME — set it before `pnpm --filter @game/web build`.
#
# Local dev default (if unset): http://localhost:4000
# Production (Render): https://<your-service>.onrender.com
NEXT_PUBLIC_SERVER_URL=http://localhost:4000
